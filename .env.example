# ──────────────────────────────────────────────────────────────
# WeaveFault Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# LLM Provider API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# LLM Provider Selection
LLM_PROVIDER=anthropic               # anthropic | openai | local
LLM_MODEL=claude-opus-4-6            # claude-opus-4-6 | gpt-4o | llama3

# Vision Model (must support vision/multimodal inputs)
VISION_MODEL=claude-opus-4-6         # must support vision/multimodal

# Vector Store / RAG Configuration
CHROMA_DB_PATH=./chroma_db
RAG_CHUNK_SIZE=512
RAG_OVERLAP=64

# Logging
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# Domain & Standard Defaults
WEAVEFAULT_DOMAIN=cloud              # cloud | embedded | mechanical | hybrid
WEAVEFAULT_STANDARD=IEC_60812        # IEC_60812 | AIAG | MIL_STD_1629 | ISO_26262
